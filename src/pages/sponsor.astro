---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sponsor — Knowledge Hub" description="Partner with Knowledge Hub to reach professionals in the Canadian not-for-profit sector. Sponsorship packages available.">

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Partner With Us</span>
      <h1>Sponsor Knowledge Hub</h1>
      <p>Align your brand with the leading annual event for Canadian not-for-profit professionals. Reach decision-makers, build goodwill, and support the community.</p>
    </div>
  </section>

  <!-- Why Sponsor -->
  <section class="section">
    <div class="container">
      <h2 class="section-heading">Why Sponsor</h2>
      <div class="value-grid">
        <div class="value-card card">
          <span class="value-icon">&#127891;</span>
          <h3>Audience Reach</h3>
          <p>Connect with board members, directors, and professionals who lead charities, religious organizations, and not-for-profits across the GTA.</p>
        </div>
        <div class="value-card card">
          <span class="value-icon">&#129309;</span>
          <h3>Community Goodwill</h3>
          <p>Demonstrate your commitment to the not-for-profit sector by supporting an event that equips organizations with practical knowledge.</p>
        </div>
        <div class="value-card card">
          <span class="value-icon">&#128161;</span>
          <h3>Brand Visibility</h3>
          <p>Your brand appears across event materials, on-site signage, the livestream, and our website — reaching both in-person and online audiences.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Audience Profile -->
  <section class="section audience-section">
    <div class="container">
      <h2 class="section-heading">Who You'll Reach</h2>
      <p class="section-desc">Knowledge Hub attracts the people who run and govern not-for-profit organizations — the professionals who make purchasing, hiring, and strategic decisions.</p>
      <div class="audience-grid">
        <div class="info-block">
          <dl>
            <dt>Attendee Roles</dt>
            <dd>Board Directors &amp; Treasurers</dd>
            <dd>Executive Directors</dd>
            <dd>Administrators &amp; Managers</dd>
            <dd>Lawyers &amp; Accountants</dd>
            <dd>Donors &amp; Volunteers</dd>
            <dt>Organizations</dt>
            <dd>Charities, churches, and not-for-profits across the Greater Toronto Area</dd>
          </dl>
        </div>
        <div class="audience-stats">
          <div class="stat">
            <span class="stat-number">4+</span>
            <span class="stat-label">Years running</span>
          </div>
          <div class="stat">
            <span class="stat-number">In-person &amp; online</span>
            <span class="stat-label">Hybrid format with livestream</span>
          </div>
          <div class="stat">
            <span class="stat-number">3</span>
            <span class="stat-label">Organizing bodies</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sponsorship Tiers -->
  <section class="section">
    <div class="container">
      <h2 class="section-heading">Sponsorship Packages</h2>
      <p class="section-desc">Flexible packages designed to match your goals and budget. All sponsors receive recognition on our website and event materials.</p>
      <div class="tiers-grid">
        <div class="tier-card card gold-tier">
          <span class="eyebrow">Gold</span>
          <h3>Premier Partner</h3>
          <ul>
            <li>Logo on all event materials &amp; signage</li>
            <li>Featured on livestream broadcast</li>
            <li>Speaking opportunity or welcome remarks</li>
            <li>Logo on website with link</li>
            <li>Social media recognition</li>
            <li>Complimentary tickets for your team</li>
          </ul>
          <a href="mailto:knowledge.hub.info@gmail.com?subject=Gold%20Sponsorship%20Inquiry" class="btn btn-primary">Contact Us</a>
        </div>
        <div class="tier-card card">
          <span class="eyebrow">Silver</span>
          <h3>Supporting Partner</h3>
          <ul>
            <li>Logo on event materials</li>
            <li>Logo on livestream</li>
            <li>Logo on website with link</li>
            <li>Social media recognition</li>
            <li>Complimentary tickets</li>
          </ul>
          <a href="mailto:knowledge.hub.info@gmail.com?subject=Silver%20Sponsorship%20Inquiry" class="btn btn-secondary">Contact Us</a>
        </div>
        <div class="tier-card card">
          <span class="eyebrow">Community</span>
          <h3>Community Supporter</h3>
          <ul>
            <li>Logo on website</li>
            <li>Social media mention</li>
            <li>Complimentary tickets</li>
          </ul>
          <a href="mailto:knowledge.hub.info@gmail.com?subject=Community%20Sponsorship%20Inquiry" class="btn btn-secondary">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Current Partners -->
  <section class="section partners-section">
    <div class="container">
      <h2 class="section-heading">Our Partners</h2>
      <p class="section-desc">Knowledge Hub is organized and supported by organizations committed to strengthening the not-for-profit sector.</p>
      <div class="partners-grid">
        <div class="partner-group">
          <span class="eyebrow" style="color: var(--text-tertiary);">Organizers</span>
          <div class="partner-logos">
            <a href="https://ucsst.ca/" target="_blank" rel="noopener"><img src="/images/orgs/ucsst-logo.png" alt="UCSS Toronto" /></a>
            <a href="https://ucpba.ca/" target="_blank" rel="noopener"><img src="/images/orgs/ucpba-logo.png" alt="UCPBA" /></a>
            <a href="https://www.ucbanational.com/" target="_blank" rel="noopener"><img src="/images/orgs/ucba-logo.png" alt="UCBA" /></a>
          </div>
        </div>
        <div class="partner-group">
          <span class="eyebrow" style="color: var(--text-tertiary);">With support from</span>
          <div class="partner-logos">
            <a href="https://www.millsandmills.ca/" target="_blank" rel="noopener"><img src="/images/orgs/mills-logo.svg" alt="Mills & Mills LLP" /></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-block">
        <h2>Interested in Partnering?</h2>
        <p>We'd love to hear from you. Reach out to discuss how we can work together to support the not-for-profit community.</p>
        <a href="mailto:knowledge.hub.info@gmail.com?subject=Sponsorship%20Inquiry" class="btn btn-primary">Get in Touch &rarr;</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: var(--sp-8) 0;
  }
  .page-hero .eyebrow {
    display: block;
    margin-bottom: var(--sp-3);
  }
  .page-hero h1 {
    font-size: 36px;
    margin-bottom: var(--sp-3);
  }
  .page-hero p {
    font-size: 16px;
    color: var(--text-secondary);
    max-width: 560px;
    line-height: 1.6;
  }

  /* ── SECTION HEADINGS ───────────── */
  .section-heading {
    font-size: 26px;
    margin-bottom: var(--sp-3);
  }
  .section-desc {
    font-size: 15.5px;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 600px;
    margin-bottom: var(--sp-7);
  }

  /* ── WHY SPONSOR ────────────────── */
  .value-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-5);
    margin-top: var(--sp-6);
  }
  .value-card {
    padding: var(--sp-6);
    text-align: center;
  }
  .value-icon {
    font-size: 28px;
    display: block;
    margin-bottom: var(--sp-4);
  }
  .value-card h3 {
    font-size: 18px;
    margin-bottom: var(--sp-2);
  }
  .value-card p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* ── AUDIENCE ───────────────────── */
  .audience-section {
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .audience-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-7);
    align-items: start;
  }
  .audience-grid dt {
    font-size: 11.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
    margin-top: var(--sp-4);
  }
  .audience-grid dt:first-child {
    margin-top: 0;
  }
  .audience-grid dd {
    font-size: 14.5px;
    color: var(--text);
    margin-top: var(--sp-1);
  }
  .audience-stats {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }
  .stat-number {
    font-family: var(--font-heading);
    font-size: 22px;
    color: var(--navy);
    font-weight: 700;
  }
  .stat-label {
    font-size: 13.5px;
    color: var(--text-secondary);
  }

  /* ── SPONSORSHIP TIERS ──────────── */
  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-5);
  }
  .tier-card {
    padding: var(--sp-6);
    display: flex;
    flex-direction: column;
  }
  .tier-card h3 {
    font-size: 20px;
    margin-bottom: var(--sp-4);
  }
  .tier-card ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    margin-bottom: var(--sp-6);
    flex-grow: 1;
  }
  .tier-card li {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.5;
    padding-left: var(--sp-4);
    position: relative;
  }
  .tier-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold-muted);
  }
  .tier-card .btn {
    text-align: center;
  }
  .gold-tier {
    border-top: 3px solid var(--gold);
  }

  /* ── PARTNERS ───────────────────── */
  .partners-section {
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .partners-grid {
    display: flex;
    flex-direction: column;
    gap: var(--sp-7);
  }
  .partner-group {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .partner-logos {
    display: flex;
    align-items: center;
    gap: var(--sp-7);
    flex-wrap: wrap;
  }
  .partner-logos img {
    height: 48px;
    width: auto;
    object-fit: contain;
    opacity: 0.85;
    transition: opacity 0.15s;
  }
  .partner-logos a:hover img {
    opacity: 1;
  }

  /* ── CTA ─────────────────────────── */
  .cta-block {
    text-align: center;
    padding: var(--sp-8) var(--sp-6);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .cta-block h2 {
    font-size: 26px;
    margin-bottom: var(--sp-3);
  }
  .cta-block p {
    font-size: 15.5px;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 480px;
    margin: 0 auto var(--sp-6);
  }

  /* ── RESPONSIVE ─────────────────── */
  @media (max-width: 768px) {
    .value-grid { grid-template-columns: 1fr; }
    .audience-grid { grid-template-columns: 1fr; }
    .tiers-grid { grid-template-columns: 1fr; }
  }
</style>
