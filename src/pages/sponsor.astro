---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Our Partners — Knowledge Hub" description="Meet the organizations that make Knowledge Hub possible. Sponsors and partners supporting the Canadian not-for-profit community.">

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Sponsors &amp; Partners</span>
      <h1>Our Partners</h1>
      <p>Knowledge Hub is made possible by the generous support of organizations committed to strengthening the Canadian not-for-profit sector.</p>
    </div>
  </section>

  <!-- Organizers -->
  <section class="section">
    <div class="container">
      <h2 class="section-heading">Organizing Bodies</h2>
      <p class="section-desc">Three Ukrainian-Canadian organizations collaborate each year to bring Knowledge Hub to life.</p>
      <div class="orgs-grid">
        <a href="https://ucsst.ca/" target="_blank" rel="noopener" class="org-card card">
          <img src="/images/orgs/ucsst-logo.png" alt="UCSS Toronto" />
          <div class="org-info">
            <h3>Ukrainian Canadian Social Services Toronto</h3>
            <p>UCSS-T provides social services and community support for Ukrainian Canadians in the Greater Toronto Area.</p>
          </div>
        </a>
        <a href="https://ucpba.ca/" target="_blank" rel="noopener" class="org-card card">
          <img src="/images/orgs/ucpba-logo.png" alt="UCPBA" />
          <div class="org-info">
            <h3>Ukrainian Canadian Professional &amp; Business Association</h3>
            <p>UCPBA connects professionals and business leaders within the Ukrainian-Canadian community.</p>
          </div>
        </a>
        <a href="https://www.ucbanational.com/" target="_blank" rel="noopener" class="org-card card">
          <img src="/images/orgs/ucba-logo.png" alt="UCBA" />
          <div class="org-info">
            <h3>Ukrainian Canadian Bar Association</h3>
            <p>UCBA represents lawyers and legal professionals of Ukrainian heritage across Canada.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Current Sponsor -->
  <section class="section sponsor-section">
    <div class="container">
      <h2 class="section-heading">Event Sponsor</h2>
      <div class="featured-sponsor card">
        <a href="https://www.millsandmills.ca/" target="_blank" rel="noopener" class="sponsor-logo-link">
          <img src="/images/orgs/mills-logo.svg" alt="Mills & Mills LLP" class="featured-logo" />
        </a>
        <div class="sponsor-info">
          <h3>Mills &amp; Mills LLP</h3>
          <p>Mills &amp; Mills LLP is a Toronto-based law firm with deep expertise serving charities, religious organizations, and not-for-profit entities. Their ongoing support of Knowledge Hub helps provide practical legal and governance knowledge to the community.</p>
          <span class="eyebrow sponsor-since">Supporting since 2022</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Become a Partner CTA -->
  <section class="section">
    <div class="container">
      <div class="cta-block">
        <h2>Interested in Partnering?</h2>
        <p>We welcome organizations that share our mission of empowering the not-for-profit community. Reach out to learn about sponsorship opportunities.</p>
        <a href="mailto:knowledge.hub.info@gmail.com?subject=Sponsorship%20Inquiry" class="btn btn-primary">Get in Touch &rarr;</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: var(--sp-8) 0;
  }
  .page-hero .eyebrow {
    display: block;
    margin-bottom: var(--sp-3);
  }
  .page-hero h1 {
    font-size: 36px;
    margin-bottom: var(--sp-3);
  }
  .page-hero p {
    font-size: 16px;
    color: var(--text-secondary);
    max-width: 560px;
    line-height: 1.6;
  }

  .section-heading {
    font-size: 26px;
    margin-bottom: var(--sp-3);
  }
  .section-desc {
    font-size: 15.5px;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 600px;
    margin-bottom: var(--sp-7);
  }

  /* ── ORGANIZERS ─────────────────── */
  .orgs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-5);
  }
  .org-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    padding: var(--sp-6);
    gap: var(--sp-5);
  }
  .org-card img {
    height: 64px;
    width: auto;
    object-fit: contain;
  }
  .org-card h3 {
    font-size: 16px;
    margin-bottom: var(--sp-2);
  }
  .org-card p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* ── FEATURED SPONSOR ──────────── */
  .sponsor-section {
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .featured-sponsor {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--sp-7);
    align-items: center;
    padding: var(--sp-7);
    border-top: 3px solid var(--gold);
  }
  .sponsor-logo-link {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .featured-logo {
    max-width: 180px;
    height: auto;
  }
  .sponsor-info h3 {
    font-size: 22px;
    margin-bottom: var(--sp-3);
  }
  .sponsor-info p {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: var(--sp-4);
  }
  .sponsor-since {
    color: var(--text-tertiary) !important;
  }

  /* ── CTA ─────────────────────────── */
  .cta-block {
    text-align: center;
    padding: var(--sp-8) var(--sp-6);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .cta-block h2 {
    font-size: 26px;
    margin-bottom: var(--sp-3);
  }
  .cta-block p {
    font-size: 15.5px;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 480px;
    margin: 0 auto var(--sp-6);
  }

  /* ── RESPONSIVE ─────────────────── */
  @media (max-width: 768px) {
    .orgs-grid { grid-template-columns: 1fr; }
    .featured-sponsor { grid-template-columns: 1fr; text-align: center; }
    .sponsor-logo-link { justify-content: center; }
  }
</style>
