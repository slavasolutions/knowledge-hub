---
import BaseLayout from '../layouts/BaseLayout.astro';
import SessionCard from '../components/SessionCard.astro';
---

<BaseLayout title="Knowledge Hub 2026 — Annual Conference for Not-For-Profits">

  <!-- ── HERO ──────────────────────────── -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-content">
        <span class="eyebrow">Thursday, April 23, 2026</span>
        <h1>An evening of practical knowledge for those who lead charities, churches, and not-for-profits.</h1>
        <p class="hero-meta">5:30 PM – 9:00 PM EDT &middot; The Old Mill, Brul&eacute; C Room, Toronto &middot; In-person &amp; livestream</p>
        <div class="hero-actions">
          <a href="https://www.eventbrite.ca/e/knowledge-hub-2026-tickets-1982313299441" class="btn btn-primary" target="_blank" rel="noopener">Register on Eventbrite →</a>
          <a href="/past-events" class="btn btn-secondary">Past Sessions</a>
        </div>
      </div>
      <div class="hero-details">
        <div class="hero-detail-card">
          <dl>
            <dt>Includes</dt>
            <dd>Presentations, networking, sandwiches, coffee &amp; tea</dd>
            <dt>Livestream</dt>
            <dd>6:30 PM – 8:15 PM EDT</dd>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SPONSORS BAR ───────────────────── -->
  <section class="sponsors-bar">
    <div class="container sponsors-inner">
      <span class="sponsors-label">Brought to you by</span>
      <div class="sponsors-logos">
        <a href="https://ucsst.ca/" target="_blank" rel="noopener" title="Ukrainian Canadian Social Services Toronto">
          <img src="/images/orgs/ucsst-logo.png" alt="UCSS Toronto" />
        </a>
        <a href="https://ucpba.ca/" target="_blank" rel="noopener" title="Ukrainian Canadian Professional and Business Association">
          <img src="/images/orgs/ucpba-logo.png" alt="UCPBA" />
        </a>
        <a href="https://www.ucbanational.com/" target="_blank" rel="noopener" title="Ukrainian Canadian Bar Association">
          <img src="/images/orgs/ucba-logo.png" alt="UCBA" />
        </a>
      </div>
      <div class="sponsors-divider"></div>
      <span class="sponsors-label">With support from</span>
      <a href="https://www.millsandmills.ca/" target="_blank" rel="noopener" class="sponsor-mills" title="Mills & Mills LLP">
        <img src="/images/orgs/mills-logo.svg" alt="Mills & Mills LLP" />
      </a>
    </div>
  </section>

  <!-- ── VIDEO ─────────────────────────── -->
  <section class="section">
    <div class="container">
      <h2>About Knowledge Hub</h2>
      <div class="video-grid">
        <div class="video-wrapper">
          <iframe
            src="https://www.youtube.com/embed/ekPn4AnyMWQ"
            title="Knowledge Hub — About"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
        <div class="video-aside">
          <p>The Knowledge Hub brings together experienced professionals who share practical knowledge to help charitable organizations become more efficient, effective, and result-oriented.</p>
          <p>This seminar is of interest to volunteers, advisors, lawyers, accountants, administrators, and directors of religious, charitable, and not-for-profit organizations.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SPEAKERS ──────────────────────── -->
  <section class="section">
    <div class="container">
      <h2>2026 Speakers</h2>
      <div class="speakers-grid">
        <div class="speaker-card card">
          <div class="speaker-avatar"><span>SK</span></div>
          <div class="speaker-info">
            <span class="eyebrow">Keynote</span>
            <h3>Sharmila Khare</h3>
            <p class="speaker-role">Director General, Charities Directorate</p>
            <p class="speaker-org">Canada Revenue Agency (CRA)</p>
          </div>
        </div>
        <div class="speaker-card card">
          <div class="speaker-avatar"><span>TK</span></div>
          <div class="speaker-info">
            <span class="eyebrow">Speaker</span>
            <h3>Taras Kulish</h3>
            <p class="speaker-role">Business &amp; Not-for-Profit Counsel</p>
            <p class="speaker-org"><a href="https://www.millsandmills.ca/" target="_blank" rel="noopener">Mills &amp; Mills LLP</a></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── EVENT DETAILS ─────────────────── -->
  <section class="section">
    <div class="container">
      <h2>Event Details</h2>
      <div class="details-grid">
        <div class="info-block">
          <dl>
            <dt>Date</dt>
            <dd>Thursday, April 23, 2026</dd>
            <dt>Time</dt>
            <dd>5:30 PM – 9:00 PM EDT</dd>
            <dt>Venue</dt>
            <dd>The Old Mill, Brul&eacute; C Room<br><span class="detail-sub">21 Old Mill Road, Toronto, ON M8X 1G5</span></dd>
            <dt>Format</dt>
            <dd>In-person and livestream</dd>
            <dt>Registration</dt>
            <dd>Free &amp; paid options available</dd>
          </dl>
        </div>
        <div class="details-aside">
          <h3>What to Expect</h3>
          <ul>
            <li>Expert presentations on legal compliance, financial management, and governance</li>
            <li>Networking reception with sandwiches, coffee &amp; tea</li>
            <li>Practical knowledge you can apply immediately</li>
            <li>Livestream option for remote attendees (6:30–8:15 PM)</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PAST SESSIONS PREVIEW ─────────── -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>From Past Events</h2>
        <a href="/past-events" class="btn btn-text">View all →</a>
      </div>
      <div class="cards-grid">
        <SessionCard
          year="2025"
          title="Minimizing Litigation Risk"
          description="Taras Kulish of Mills & Mills LLP shared insights on navigating legal challenges and protecting not-for-profit organizations from litigation risk."
          href="/past-events/2025"
          linkText="View details →"
        />
        <SessionCard
          year="2024"
          title="Financial Reporting Best Practices"
          description="Key strategies for transparent and compliant financial reporting in the not-for-profit sector."
          href="/past-events/2024"
          linkText="View details →"
        />
        <SessionCard
          year="2023"
          title="Governance Essentials"
          description="Foundational governance structures and board responsibilities for charitable organizations."
          href="/past-events/2023"
          linkText="View details →"
        />
      </div>
    </div>
  </section>


</BaseLayout>

<style>
  /* ── HERO ────────────────────────── */
  .hero {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: var(--sp-8) 0 var(--sp-9);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: var(--sp-8);
    align-items: start;
  }
  .hero .eyebrow {
    display: block;
    margin-bottom: var(--sp-4);
  }
  .hero h1 {
    font-size: 30px;
    font-weight: 400;
    line-height: 1.35;
    color: var(--navy);
    max-width: 520px;
    margin-bottom: var(--sp-4);
  }
  .hero-meta {
    font-size: 14px;
    color: var(--text-secondary);
    margin-bottom: var(--sp-6);
  }
  .hero-actions {
    display: flex;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }
  .hero .btn-primary {
    background: var(--navy);
    color: var(--surface);
  }
  .hero .btn-primary:hover {
    background: var(--navy-light);
  }

  /* ── HERO DETAIL CARD ──────────── */
  .hero-detail-card {
    border-left: 3px solid var(--gold);
    padding: var(--sp-5);
    background: var(--surface-raised);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }
  .hero-detail-card dt {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: var(--sp-3);
  }
  .hero-detail-card dt:first-child { margin-top: 0; }
  .hero-detail-card dd {
    font-size: 14.5px;
    color: var(--text);
    margin-left: 0;
  }
  .detail-sub {
    font-size: 13px;
    color: var(--text-tertiary);
  }

  /* ── VIDEO ─────────────────────── */
  .video-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--sp-6);
    align-items: start;
  }
  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  .video-aside p {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: var(--sp-4);
  }

  /* ── SPEAKERS ──────────────────── */
  .speakers-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-4);
  }
  .speaker-card {
    display: flex;
    gap: var(--sp-4);
    align-items: start;
  }
  .speaker-avatar {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
    background: var(--navy);
    color: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 18px;
    flex-shrink: 0;
  }
  .speaker-info { flex: 1; }
  .speaker-info h3 {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 400;
    color: var(--navy);
    margin: var(--sp-1) 0 var(--sp-1);
  }
  .speaker-role { font-size: 13.5px; color: var(--text-secondary); line-height: 1.4; }
  .speaker-org { font-size: 13px; color: var(--text-tertiary); }
  .speaker-org a {
    color: var(--navy);
    font-weight: 500;
    text-decoration: none;
  }
  .speaker-org a:hover { text-decoration: underline; }

  /* ── DETAILS ─────────────────────── */
  h2 { font-size: 26px; margin-bottom: var(--sp-6); }
  .details-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-7);
    align-items: start;
  }
  .details-aside h3 {
    font-size: 15px;
    font-weight: 600;
    font-family: var(--font-body);
    color: var(--text);
    margin-bottom: var(--sp-3);
  }
  .details-aside ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .details-aside li {
    font-size: 14.5px;
    color: var(--text-secondary);
    padding-left: var(--sp-4);
    position: relative;
    line-height: 1.5;
  }
  .details-aside li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 9px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold);
  }

  /* ── SECTION HEADER ──────────────── */
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  /* ── CARDS GRID ──────────────────── */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }

  /* ── SPONSORS BAR ────────────────── */
  .sponsors-bar {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: var(--sp-5) 0;
  }
  .sponsors-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-5);
    flex-wrap: wrap;
  }
  .sponsors-label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-tertiary);
    white-space: nowrap;
  }
  .sponsors-logos {
    display: flex;
    align-items: center;
    gap: var(--sp-6);
  }
  .sponsors-logos a {
    display: block;
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.2s;
  }
  .sponsors-logos a:hover { opacity: 1; }
  .sponsors-logos img {
    height: 56px;
    width: auto;
    object-fit: contain;
  }
  .sponsors-divider {
    width: 1px;
    height: 40px;
    background: var(--border);
  }
  .sponsor-mills {
    display: block;
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.2s;
  }
  .sponsor-mills:hover { opacity: 1; }
  .sponsor-mills img {
    height: 28px;
    width: auto;
    object-fit: contain;
  }

  @media (max-width: 768px) {
    .hero-grid { grid-template-columns: 1fr; }
    .video-grid { grid-template-columns: 1fr; }
    .speakers-grid { grid-template-columns: 1fr; }
    .details-grid { grid-template-columns: 1fr; }
    .cards-grid { grid-template-columns: 1fr; }
    .sponsors-inner { gap: var(--sp-4); }
    .sponsors-logos { gap: var(--sp-4); }
    .sponsors-logos img { height: 40px; }
    .sponsors-divider { display: none; }
  }
</style>
