---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="footer-wordmark">Knowledge Hub</span>
      <span class="footer-orgs">UCSS-T &middot; UCPBA &middot; UCBA</span>
    </div>

    <div class="footer-links">
      <div class="footer-col">
        <span class="footer-label">Event</span>
        <a href="/about">About</a>
        <a href="/speakers">Speakers</a>
        <a href="/past-events">Past Events</a>
        <a href="/sponsor">Sponsor</a>
        <a href="https://www.eventbrite.ca/e/knowledge-hub-2026-tickets-1982313299441" target="_blank" rel="noopener">Register</a>
      </div>
      <div class="footer-col">
        <span class="footer-label">Organizers</span>
        <a href="https://ucsst.ca/" target="_blank" rel="noopener">UCSS Toronto</a>
        <a href="https://ucpba.ca/" target="_blank" rel="noopener">UCPBA</a>
        <a href="https://www.ucbanational.com/" target="_blank" rel="noopener">UCBA</a>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-support">With support from <a href="https://www.millsandmills.ca/" target="_blank" rel="noopener">Mills &amp; Mills LLP</a></span>
      <span class="footer-copy">&copy; {new Date().getFullYear()} Knowledge Hub. All rights reserved.</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy);
    color: rgba(255,255,255,0.5);
    padding: var(--sp-8) 0 var(--sp-7);
    margin-top: var(--sp-9);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-7);
  }
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .footer-wordmark {
    font-family: var(--font-heading);
    font-size: 20px;
    color: var(--surface);
  }
  .footer-orgs {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
  }
  .footer-links {
    display: flex;
    gap: var(--sp-8);
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .footer-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.3);
    margin-bottom: var(--sp-1);
  }
  .footer-col a {
    font-size: 13.5px;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    font-weight: 400;
  }
  .footer-col a:hover {
    color: var(--surface);
  }
  .footer-bottom {
    grid-column: 1 / -1;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: var(--sp-5);
    display: flex;
    justify-content: space-between;
    font-size: 12.5px;
  }
  .footer-bottom a {
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    font-weight: 500;
  }
  .footer-bottom a:hover { color: var(--surface); }
  .footer-copy {
    color: rgba(255,255,255,0.3);
  }

  @media (max-width: 640px) {
    .footer-inner { grid-template-columns: 1fr; gap: var(--sp-6); }
    .footer-bottom { flex-direction: column; gap: var(--sp-2); }
  }
</style>
